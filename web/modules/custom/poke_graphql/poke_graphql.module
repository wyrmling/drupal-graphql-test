<?php

/**
 * @file
 * Hook implementations for poke_graphql module.
 */

/**
 * Implements hook_theme().
 */
function poke_graphql_theme(): array {
  return [
    'poke_graphql_list' => [
      'variables' => [
        'items'       => [],
        'error'       => NULL,
        'page'        => 0,
        'total_pages' => 1,
      ],
    ],
    'poke_graphql_detail' => [
      'variables' => [
        'pokemon' => [],
        'error'   => NULL,
      ],
    ],
  ];
}
