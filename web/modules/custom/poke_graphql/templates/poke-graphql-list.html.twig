{# {{ attach_library('poke_theme/global') }} #}
<main class="poke-page">
  <h1 class="poke-page__title">Pokemon</h1>

  {% if error %}
    <div class="poke-alert poke-alert--error" role="alert">
      <strong>Error:</strong> {{ error }}
    </div>
  {% elseif items is empty %}
    <div class="poke-alert poke-alert--empty" role="status">
      No Pokemon found.
    </div>
  {% else %}
    <ul class="poke-grid">
      {% for pokemon in items %}
        {%
          set types = pokemon.pokemon_v2_pokemontypes
            | map(t => t.pokemon_v2_type.name)
            | join(', ')
        %}
        <li class="poke-card">
          <span class="poke-card__id">#{{ pokemon.id }}</span>
          <h2 class="poke-card__name">{{ pokemon.name | capitalize }}</h2>
          <dl class="poke-card__meta">
            <dt>Type</dt>  <dd>{{ types }}</dd>
            <dt>Height</dt><dd>{{ pokemon.height }}</dd>
            <dt>Weight</dt><dd>{{ pokemon.weight }}</dd>
            <dt>XP</dt>    <dd>{{ pokemon.base_experience }}</dd>
          </dl>
          <a class="poke-btn" href="{{ path('poke_graphql.detail', {id: pokemon.id}) }}">
            View Details
          </a>
        </li>
      {% endfor %}
    </ul>

    {% if total_pages > 1 %}
      <nav class="poke-pagination" aria-label="Pagination">
        {% if page > 0 %}
          <a class="poke-pagination__btn" href="{{ path('poke_graphql.list') }}?page={{ page - 1 }}">← Prev</a>
        {% endif %}
        <span class="poke-pagination__info">Page {{ page + 1 }} of {{ total_pages }}</span>
        {% if page + 1 < total_pages %}
          <a class="poke-pagination__btn" href="{{ path('poke_graphql.list') }}?page={{ page + 1 }}">Next →</a>
        {% endif %}
      </nav>
    {% endif %}
  {% endif %}
</main>
